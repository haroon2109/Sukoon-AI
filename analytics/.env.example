# Superset Internal Database
POSTGRES_USER=superset
POSTGRES_PASSWORD=superset
POSTGRES_DB=superset
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DIALECT=postgresql

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379

# Superset Secret Key (Required for starting up)
# Generate a secure key using: openssl rand -base64 42
SUPERSET_SECRET_KEY=YOUR_SECURE_SECRET_KEY_HERE

# Supabase Connection details for your visualizations
# In Superset UI, you will use this URI to connect your BI dashboards to Supabase:
# postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres
SUPABASE_DB_URI=postgresql://postgres:your_supabase_password@db.your-supabase-project.supabase.co:5432/postgres
